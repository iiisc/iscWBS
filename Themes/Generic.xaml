<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:iscWBS.Converters">
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="WbsStatusNotStartedBrush" Color="#808080" />
            <SolidColorBrush x:Key="WbsStatusInProgressBrush" Color="#0078D4" />
            <SolidColorBrush x:Key="WbsStatusCompleteBrush"   Color="#107C10" />
            <SolidColorBrush x:Key="WbsStatusBlockedBrush"    Color="#C50F1F" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="WbsStatusNotStartedBrush" Color="#9E9E9E" />
            <SolidColorBrush x:Key="WbsStatusInProgressBrush" Color="#60CDFF" />
            <SolidColorBrush x:Key="WbsStatusCompleteBrush"   Color="#6CCB5F" />
            <SolidColorBrush x:Key="WbsStatusBlockedBrush"    Color="#FF99A4" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="HighContrast">
            <SolidColorBrush x:Key="WbsStatusNotStartedBrush" Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="WbsStatusInProgressBrush" Color="{ThemeResource SystemColorHighlightColor}" />
            <SolidColorBrush x:Key="WbsStatusCompleteBrush"   Color="{ThemeResource SystemColorWindowTextColor}" />
            <SolidColorBrush x:Key="WbsStatusBlockedBrush"    Color="{ThemeResource SystemColorHighlightTextColor}" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
