<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="iscWBS.Views.Controls.NewProjectControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Spacing="12" MinWidth="380" Padding="0,4,0,4">

        <TextBox
            x:Name="TxtName"
            Header="Project Name *"
            PlaceholderText="Enter project name"
            AutomationProperties.Name="Project name" />

        <TextBox
            x:Name="TxtOwner"
            Header="Owner"
            PlaceholderText="Enter owner name"
            AutomationProperties.Name="Project owner" />

        <ComboBox
            x:Name="CbxCurrency"
            Header="Currency"
            AutomationProperties.Name="Project currency"
            Width="160" />

        <StackPanel Spacing="4">
            <TextBlock
                Text="Save Location *"
                Style="{ThemeResource CaptionTextBlockStyle}" />
            <TextBlock
                x:Name="TxtSavePath"
                Text="No folder selected"
                Style="{ThemeResource BodyTextBlockStyle}"
                TextWrapping="Wrap" />
            <Button
                x:Name="BtnPickFolder"
                Content="Choose Folder..."
                AutomationProperties.Name="Choose save folder"
                Click="BtnPickFolder_Click" />
        </StackPanel>

    </StackPanel>
</UserControl>
