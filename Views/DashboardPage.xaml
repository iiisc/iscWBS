<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="iscWBS.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    xmlns:vm="using:iscWBS.ViewModels"
    xmlns:models="using:iscWBS.Core.Models"
    xmlns:converters="using:iscWBS.Converters">

    <Page.Resources>
        <converters:StatusToStringConverter  x:Key="StatusToStringConverter" />
        <converters:StatusToBrushConverter   x:Key="StatusToBrushConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel
            Grid.Row="0"
            Orientation="Horizontal" Spacing="8"
            Margin="12,12,12,0" VerticalAlignment="Center">
            <TextBlock
                x:Uid="DashboardPage_Title"
                Text="Dashboard"
                Style="{ThemeResource TitleLargeTextBlockStyle}" />
            <Border
                Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                <TextBlock
                    Text="BETA" FontSize="11" FontWeight="SemiBold"
                    Foreground="{ThemeResource SystemFillColorCautionBrush}"
                    AutomationProperties.Name="Beta feature" />
            </Border>
        </StackPanel>

        <!-- Filters + Export button -->
        <Grid Grid.Row="1" Margin="12,8" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <CalendarDatePicker
                Grid.Column="0"
                x:Uid="DashboardPage_FilterStartDate"
                Date="{x:Bind ViewModel.FilterStartDate, Mode=TwoWay}"
                PlaceholderText="Start date"
                AutomationProperties.Name="Filter start date" />
            <CalendarDatePicker
                Grid.Column="1"
                x:Uid="DashboardPage_FilterEndDate"
                Date="{x:Bind ViewModel.FilterEndDate, Mode=TwoWay}"
                PlaceholderText="End date"
                AutomationProperties.Name="Filter end date" />
            <ComboBox
                Grid.Column="2"
                x:Uid="DashboardPage_FilterAssignee"
                ItemsSource="{x:Bind ViewModel.AssigneeOptions, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedAssignee, Mode=TwoWay}"
                PlaceholderText="Assignee"
                MinWidth="140"
                AutomationProperties.Name="Filter by assignee" />
            <ComboBox
                Grid.Column="3"
                x:Uid="DashboardPage_FilterStatus"
                ItemsSource="{x:Bind ViewModel.StatusOptions}"
                SelectedItem="{x:Bind ViewModel.SelectedStatus, Mode=TwoWay}"
                PlaceholderText="Status"
                MinWidth="140"
                AutomationProperties.Name="Filter by status">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource StatusToStringConverter}}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <Button
                Grid.Column="5"
                x:Name="ExportPdfButton"
                Style="{ThemeResource AccentButtonStyle}"
                VerticalAlignment="Center"
                AutomationProperties.Name="Export project status report to PDF"
                Click="ExportPdfButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE792;" FontSize="14" />
                    <TextBlock x:Uid="DashboardPage_ExportPdfBtn" Text="Export to PDF" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- KPI strip -->
        <Grid Grid.Row="2" Margin="12,0,12,8" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" CornerRadius="8" Padding="12"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Bind ViewModel.OverallPercentText, Mode=OneWay}"
                               Style="{ThemeResource TitleTextBlockStyle}"
                               AutomationProperties.Name="Overall percent complete" />
                    <TextBlock x:Uid="DashboardPage_KpiCompletePercent" Text="% Complete" Style="{ThemeResource CaptionTextBlockStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" CornerRadius="8" Padding="12"
                    Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Bind ViewModel.CompleteCount, Mode=OneWay}"
                               Style="{ThemeResource TitleTextBlockStyle}"
                               Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                               AutomationProperties.Name="Complete task count" />
                    <TextBlock x:Uid="DashboardPage_KpiComplete" Text="Complete" Style="{ThemeResource CaptionTextBlockStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" CornerRadius="8" Padding="12"
                    Background="{ThemeResource SystemFillColorAttentionBackgroundBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Bind ViewModel.InProgressCount, Mode=OneWay}"
                               Style="{ThemeResource TitleTextBlockStyle}"
                               Foreground="{ThemeResource SystemFillColorAttentionBrush}"
                               AutomationProperties.Name="In progress task count" />
                    <TextBlock x:Uid="DashboardPage_KpiInProgress" Text="In Progress" Style="{ThemeResource CaptionTextBlockStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="3" CornerRadius="8" Padding="12"
                    Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Bind ViewModel.AtRiskCount, Mode=OneWay}"
                               Style="{ThemeResource TitleTextBlockStyle}"
                               Foreground="{ThemeResource SystemFillColorCautionBrush}"
                               AutomationProperties.Name="At risk task count" />
                    <TextBlock x:Uid="DashboardPage_KpiAtRisk" Text="At Risk" Style="{ThemeResource CaptionTextBlockStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="4" CornerRadius="8" Padding="12"
                    Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Bind ViewModel.OverdueCount, Mode=OneWay}"
                               Style="{ThemeResource TitleTextBlockStyle}"
                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                               AutomationProperties.Name="Overdue task count" />
                    <TextBlock x:Uid="DashboardPage_KpiOverdue" Text="Overdue" Style="{ThemeResource CaptionTextBlockStyle}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="5" CornerRadius="8" Padding="12"
                    Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="4">
                    <TextBlock Text="{x:Bind ViewModel.BlockedCount, Mode=OneWay}"
                               Style="{ThemeResource TitleTextBlockStyle}"
                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                               AutomationProperties.Name="Blocked task count" />
                    <TextBlock x:Uid="DashboardPage_KpiBlocked" Text="Blocked" Style="{ThemeResource CaptionTextBlockStyle}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Main body: deliverables (left) + status chart and milestones (right) -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <Grid Margin="12,0,12,12" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <!-- Deliverables table -->
                <StackPanel Grid.Column="0" Spacing="8">
                    <TextBlock x:Uid="DashboardPage_DeliverablesTitle" Text="Deliverables" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <ListView
                        ItemsSource="{x:Bind ViewModel.DeliverableRows, Mode=OneWay}"
                        SelectionMode="None"
                        AutomationProperties.Name="Deliverables list">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:DeliverableRow">
                                <Border
                                    Padding="4,10"
                                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                                    BorderThickness="0,0,0,1">
                                    <Grid RowSpacing="6" ColumnSpacing="12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Row="0" Grid.Column="0"
                                            Text="{x:Bind Code}"
                                            FontWeight="SemiBold" FontSize="11"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            VerticalAlignment="Center" MinWidth="52" />
                                        <TextBlock
                                            Grid.Row="0" Grid.Column="1"
                                            Text="{x:Bind Title}"
                                            FontWeight="SemiBold"
                                            TextTrimming="CharacterEllipsis"
                                            VerticalAlignment="Center" />
                                        <TextBlock
                                            Grid.Row="0" Grid.Column="2"
                                            Text="{x:Bind Status, Converter={StaticResource StatusToStringConverter}}"
                                            Foreground="{x:Bind Status, Converter={StaticResource StatusToBrushConverter}}"
                                            FontSize="11" FontWeight="SemiBold"
                                            VerticalAlignment="Center" />
                                        <TextBlock
                                            Grid.Row="0" Grid.Column="3"
                                            Text="{x:Bind DueDateText}"
                                            FontSize="11"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            VerticalAlignment="Center" />

                                        <Grid
                                            Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4"
                                            ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ProgressBar
                                                Grid.Column="0"
                                                Value="{x:Bind ProgressFraction}"
                                                Minimum="0" Maximum="1"
                                                Height="6"
                                                AutomationProperties.Name="Deliverable progress" />
                                            <TextBlock
                                                Grid.Column="1"
                                                Text="{x:Bind ProgressPercentText}"
                                                FontSize="11"
                                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                VerticalAlignment="Center" />
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>

                <!-- Status donut + upcoming milestones -->
                <StackPanel Grid.Column="1" Spacing="20">

                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="DashboardPage_StatusBreakdownTitle" Text="Status Breakdown" Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <lvc:PieChart
                            Series="{x:Bind ViewModel.StatusSeries, Mode=OneWay}"
                            Height="220"
                            AutomationProperties.Name="Status breakdown chart" />
                    </StackPanel>

                    <StackPanel Spacing="8">
                        <TextBlock x:Uid="DashboardPage_UpcomingMilestonesTitle" Text="Upcoming Milestones &#x2014; Next 60 Days" Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <ListView
                            ItemsSource="{x:Bind ViewModel.UpcomingMilestones, Mode=OneWay}"
                            SelectionMode="None"
                            AutomationProperties.Name="Upcoming milestones list">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:MilestoneRowViewModel">
                                    <Grid ColumnSpacing="8" Padding="0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Column="0"
                                            Text="{x:Bind Milestone.Title}"
                                            TextTrimming="CharacterEllipsis"
                                            VerticalAlignment="Center" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{x:Bind DueDateLabel}"
                                            FontSize="11"
                                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                            VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>

                </StackPanel>
            </Grid>
        </ScrollViewer>

    </Grid>
</Page>
