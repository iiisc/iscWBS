<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="iscWBS.Views.GanttPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar: left-aligned so the zoom control stays away from the caption buttons -->
        <StackPanel
            Grid.Row="0"
            Orientation="Horizontal"
            Spacing="16"
            Padding="16,8">
            <TextBlock
                x:Uid="GanttPage_Title"
                Text="Gantt Chart"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                VerticalAlignment="Center" />
            <Border
                Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                <TextBlock
                    Text="BETA" FontSize="11" FontWeight="SemiBold"
                    Foreground="{ThemeResource SystemFillColorCautionBrush}"
                    AutomationProperties.Name="Beta feature" />
            </Border>
            <TextBlock
                x:Uid="GanttPage_ZoomLabel"
                Text="Zoom"
                VerticalAlignment="Center"
                Style="{ThemeResource BodyTextBlockStyle}" />
            <ComboBox
                x:Name="ZoomCombo"
                Width="110"
                SelectedIndex="0"
                SelectionChanged="ZoomCombo_SelectionChanged"
                AutomationProperties.Name="Zoom level">
                <ComboBoxItem x:Uid="GanttPage_ZoomDay" Content="Day" />
                <ComboBoxItem x:Uid="GanttPage_ZoomWeek" Content="Week" />
                <ComboBoxItem x:Uid="GanttPage_ZoomMonth" Content="Month" />
            </ComboBox>
        </StackPanel>

        <!-- Sticky header row — never scrolls vertically -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border
                Grid.Column="0"
                BorderThickness="0,0,1,0"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                <Canvas x:Name="LabelHeaderCanvas" />
            </Border>
            <ScrollViewer
                x:Name="HeaderScrollViewer"
                Grid.Column="1"
                HorizontalScrollBarVisibility="Hidden"
                VerticalScrollBarVisibility="Disabled"
                IsTabStop="False">
                <Canvas x:Name="HeaderCanvas" />
            </ScrollViewer>
        </Grid>

        <!-- Scrollable task rows -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border
                Grid.Column="0"
                BorderThickness="0,0,1,0"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                <ScrollViewer
                    x:Name="LabelScrollViewer"
                    VerticalScrollBarVisibility="Hidden"
                    HorizontalScrollBarVisibility="Disabled"
                    IsTabStop="False">
                    <Canvas x:Name="LabelCanvas" />
                </ScrollViewer>
            </Border>
            <ScrollViewer
                x:Name="GanttScrollViewer"
                Grid.Column="1"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Auto"
                ViewChanged="GanttScrollViewer_ViewChanged">
                <Canvas x:Name="ChartCanvas" />
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>

