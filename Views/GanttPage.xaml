<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="iscWBS.Views.GanttPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel
            Grid.Row="0"
            Orientation="Horizontal"
            Spacing="16"
            Padding="12,8">
            <TextBlock
                Text="Gantt"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                VerticalAlignment="Center" />
            <TextBlock Text="Zoom:" VerticalAlignment="Center" />
            <RadioButton
                x:Name="ZoomDay"
                Content="Day"
                IsChecked="True"
                Checked="ZoomDay_Checked"
                AutomationProperties.Name="Day zoom" />
            <RadioButton
                x:Name="ZoomWeek"
                Content="Week"
                Checked="ZoomWeek_Checked"
                AutomationProperties.Name="Week zoom" />
            <RadioButton
                x:Name="ZoomMonth"
                Content="Month"
                Checked="ZoomMonth_Checked"
                AutomationProperties.Name="Month zoom" />
        </StackPanel>

        <!-- Canvas inside double-axis ScrollViewer; Canvas is created in code-behind -->
        <ScrollViewer
            x:Name="GanttScrollViewer"
            Grid.Row="1"
            HorizontalScrollBarVisibility="Auto"
            VerticalScrollBarVisibility="Auto" />
    </Grid>
</Page>

