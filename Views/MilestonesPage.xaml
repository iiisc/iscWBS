<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="iscWBS.Views.MilestonesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:iscWBS.ViewModels"
    xmlns:models="using:iscWBS.Core.Models"
    xmlns:converters="using:iscWBS.Converters">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Create milestone toolbar -->
        <StackPanel
            Grid.Row="0"
            Orientation="Horizontal"
            Spacing="8"
            Padding="12,8">
            <TextBox
                Text="{x:Bind ViewModel.NewTitle, Mode=TwoWay}"
                PlaceholderText="Milestone title"
                Width="220"
                AutomationProperties.Name="New milestone title" />
            <CalendarDatePicker
                Date="{x:Bind ViewModel.NewDueDate, Mode=TwoWay}"
                AutomationProperties.Name="New milestone due date" />
            <Button
                Content="Add Milestone"
                Command="{x:Bind ViewModel.AddMilestoneCommand}"
                Style="{ThemeResource AccentButtonStyle}"
                AutomationProperties.Name="Add milestone" />
        </StackPanel>

        <!-- Content: list + detail -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <!-- Milestones list -->
            <ListView
                Grid.Column="0"
                ItemsSource="{x:Bind ViewModel.Milestones, Mode=OneWay}"
                SelectedItem="{x:Bind ViewModel.SelectedMilestone, Mode=TwoWay}"
                SelectionMode="Single">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:MilestoneRowViewModel">
                        <Grid ColumnSpacing="12" Padding="0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="88" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="32" />
                            </Grid.ColumnDefinitions>

                            <!-- Status badge -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock
                                    Text="✓ Complete"
                                    Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                    FontWeight="SemiBold"
                                    FontSize="12"
                                    VerticalAlignment="Center"
                                    Visibility="{x:Bind Milestone.IsComplete, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <TextBlock
                                    Text="Overdue"
                                    Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                    FontWeight="SemiBold"
                                    FontSize="12"
                                    VerticalAlignment="Center"
                                    Visibility="{x:Bind IsOverdue, Converter={StaticResource BoolToVisibilityConverter}}" />
                                <TextBlock
                                    Text="Upcoming"
                                    FontSize="12"
                                    VerticalAlignment="Center"
                                    Visibility="{x:Bind IsUpcoming, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </StackPanel>

                            <TextBlock
                                Grid.Column="1"
                                Text="{x:Bind Milestone.Title}"
                                TextTrimming="CharacterEllipsis"
                                VerticalAlignment="Center" />
                            <TextBlock
                                Grid.Column="2"
                                Text="{x:Bind DueDateLabel}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                FontSize="12"
                                VerticalAlignment="Center" />
                            <TextBlock
                                Grid.Column="3"
                                Text="{x:Bind LinkedNodeCountLabel}"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                FontSize="12"
                                VerticalAlignment="Center" />
                            <Button
                                Grid.Column="4"
                                Content="&#xE74D;"
                                FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                FontSize="12"
                                Padding="4"
                                Click="DeleteMilestone_Click"
                                AutomationProperties.Name="Delete milestone" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Separator -->
            <Rectangle
                Grid.Column="1"
                Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                Width="1" />

            <!-- Detail panel -->
            <ScrollViewer
                Grid.Column="2"
                VerticalScrollBarVisibility="Auto"
                Visibility="{x:Bind ViewModel.IsDetailVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <StackPanel Spacing="12" Padding="16">

                    <TextBlock
                        Text="Milestone Details"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />

                    <StackPanel Spacing="4">
                        <TextBlock Text="Title" Style="{ThemeResource CaptionTextBlockStyle}" />
                        <TextBox
                            Text="{x:Bind ViewModel.EditTitle, Mode=TwoWay}"
                            AutomationProperties.Name="Milestone title" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock Text="Due Date" Style="{ThemeResource CaptionTextBlockStyle}" />
                        <CalendarDatePicker
                            Date="{x:Bind ViewModel.EditDueDate, Mode=TwoWay}"
                            HorizontalAlignment="Stretch"
                            AutomationProperties.Name="Milestone due date" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                        <Button
                            Content="Save"
                            Command="{x:Bind ViewModel.SaveEditCommand}"
                            Style="{ThemeResource AccentButtonStyle}"
                            AutomationProperties.Name="Save milestone" />
                        <Button
                            Content="Mark Complete"
                            Command="{x:Bind ViewModel.MarkCompleteCommand}"
                            CommandParameter="{x:Bind ViewModel.SelectedMilestone, Mode=OneWay}"
                            Visibility="{x:Bind ViewModel.IsSelectedMilestoneIncomplete, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                            AutomationProperties.Name="Mark milestone complete" />
                    </StackPanel>

                    <TextBlock
                        Text="Linked WBS Nodes"
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        Margin="0,8,0,0" />

                    <ItemsControl ItemsSource="{x:Bind ViewModel.LinkedNodes, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:WbsNode">
                                <Grid ColumnSpacing="8" Padding="0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="32" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock
                                        Grid.Column="0"
                                        Text="{x:Bind Code}"
                                        FontWeight="SemiBold"
                                        VerticalAlignment="Center" />
                                    <TextBlock
                                        Grid.Column="1"
                                        Text="{x:Bind Title}"
                                        TextTrimming="CharacterEllipsis"
                                        VerticalAlignment="Center" />
                                    <Button
                                        Grid.Column="2"
                                        Content="&#xE74D;"
                                        FontFamily="{ThemeResource SymbolThemeFontFamily}"
                                        FontSize="12"
                                        Padding="4"
                                        Click="UnlinkNode_Click"
                                        AutomationProperties.Name="Remove linked node" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock
                        Text="Link a WBS Node"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        Margin="0,8,0,0" />

                    <ComboBox
                        ItemsSource="{x:Bind ViewModel.AllProjectNodes, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.NewLinkedNode, Mode=TwoWay}"
                        PlaceholderText="Select node to link"
                        HorizontalAlignment="Stretch"
                        AutomationProperties.Name="Node to link">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="models:WbsNode">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{x:Bind Code}" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind Title}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Button
                        Content="Link Node"
                        Command="{x:Bind ViewModel.AddLinkedNodeCommand}"
                        AutomationProperties.Name="Link selected node" />

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
