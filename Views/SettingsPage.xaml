<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="iscWBS.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:iscWBS.Converters"
    xmlns:viewmodels="using:iscWBS.ViewModels">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="24" Padding="32" MaxWidth="680" HorizontalAlignment="Left">

            <TextBlock
                x:Uid="SettingsPage_Title"
                Text="Settings"
                Style="{ThemeResource TitleLargeTextBlockStyle}" />

            <!-- Project -->
            <StackPanel Spacing="8">
                <TextBlock
                    x:Uid="SettingsPage_ProjectSection"
                    Text="Project"
                    Style="{ThemeResource SubtitleTextBlockStyle}" />

                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                    <StackPanel Spacing="12">

                        <!-- Active project info -->
                        <StackPanel
                            Spacing="2"
                            Visibility="{x:Bind ViewModel.HasActiveProject, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock
                                x:Uid="SettingsPage_ActiveProjectLabel"
                                Text="Active Project"
                                Style="{ThemeResource CaptionTextBlockStyle}" />
                            <TextBlock
                                Text="{x:Bind ViewModel.ActiveProjectName, Mode=OneWay}"
                                FontWeight="SemiBold"
                                AutomationProperties.Name="Active project name" />
                        </StackPanel>

                        <!-- No active project message -->
                        <TextBlock
                            x:Uid="SettingsPage_NoActiveProject"
                            Text="No project is currently open."
                            Style="{ThemeResource CaptionTextBlockStyle}"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Visibility="{x:Bind ViewModel.HasNoActiveProject, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                        <!-- Action buttons -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button
                                x:Uid="SettingsPage_NewProjectBtn"
                                Content="New Project"
                                Click="BtnNewProject_Click"
                                AutomationProperties.Name="Create new project" />
                            <Button
                                x:Uid="SettingsPage_OpenProjectBtn"
                                Content="Open Project"
                                Click="BtnOpenProject_Click"
                                AutomationProperties.Name="Open existing project" />
                            <Button
                                x:Uid="SettingsPage_CloseProjectBtn"
                                Content="Close Project"
                                Command="{x:Bind ViewModel.CloseProjectCommand}"
                                IsEnabled="{x:Bind ViewModel.HasActiveProject, Mode=OneWay}"
                                AutomationProperties.Name="Close current project" />
                        </StackPanel>

                        <!-- Recent projects -->
                        <StackPanel
                            Spacing="6"
                            Visibility="{x:Bind ViewModel.HasRecentProjects, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock
                                x:Uid="SettingsPage_RecentProjectsLabel"
                                Text="Recent Projects"
                                Style="{ThemeResource CaptionTextBlockStyle}" />
                            <ListView
                                x:Name="RecentProjectsList"
                                ItemsSource="{x:Bind ViewModel.RecentProjects, Mode=OneWay}"
                                IsItemClickEnabled="True"
                                SelectionMode="None"
                                ItemClick="RecentProjectsList_ItemClick"
                                AutomationProperties.Name="Recent projects list">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Grid ColumnSpacing="12" Padding="0,2">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                Text="{x:Bind}"
                                                TextTrimming="CharacterEllipsis"
                                                VerticalAlignment="Center"
                                                AutomationProperties.Name="{x:Bind}" />
                                            <Button
                                                Grid.Column="1"
                                                x:Uid="SettingsPage_RemoveBtn"
                                                Tag="{x:Bind}"
                                                Content="Remove"
                                                Click="RemoveRecentProject_Click"
                                                VerticalAlignment="Center"
                                                AutomationProperties.Name="Remove from recent projects" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>

                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Software Updates -->
            <StackPanel Spacing="8">
                <TextBlock
                    x:Uid="SettingsPage_UpdatesSection"
                    Text="Software Updates"
                    Style="{ThemeResource SubtitleTextBlockStyle}" />

                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                    <StackPanel Spacing="12">

                        <!-- Version row + check button -->
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="2" VerticalAlignment="Center">
                                <TextBlock
                                    x:Uid="SettingsPage_CurrentVersionLabel"
                                    Text="Current Version"
                                    Style="{ThemeResource CaptionTextBlockStyle}" />
                                <TextBlock
                                    Text="{x:Bind ViewModel.CurrentVersion, Mode=OneWay}"
                                    FontWeight="SemiBold"
                                    AutomationProperties.Name="Current application version" />
                            </StackPanel>

                            <Button
                                Grid.Column="1"
                                x:Uid="SettingsPage_CheckUpdatesBtn"
                                Content="Check for Updates"
                                Command="{x:Bind ViewModel.CheckForUpdateCommand}"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="Check for updates" />
                        </Grid>

                        <!-- Checking spinner -->
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="8"
                            Visibility="{x:Bind ViewModel.IsCheckingForUpdate, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ProgressRing
                                IsActive="True"
                                Width="16"
                                Height="16" />
                            <TextBlock
                                x:Uid="SettingsPage_CheckingText"
                                Text="Checking for updates…"
                                Style="{ThemeResource CaptionTextBlockStyle}"
                                VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Info status (up to date / download cancelled) -->
                        <InfoBar
                            IsOpen="{x:Bind ViewModel.HasStatusMessage, Mode=OneWay}"
                            Message="{x:Bind ViewModel.UpdateStatusMessage, Mode=OneWay}"
                            Severity="Informational"
                            IsClosable="False" />

                        <!-- Error status (not found / rate limited / network failure) -->
                        <InfoBar
                            IsOpen="{x:Bind ViewModel.HasErrorMessage, Mode=OneWay}"
                            Message="{x:Bind ViewModel.UpdateErrorMessage, Mode=OneWay}"
                            Severity="Error"
                            IsClosable="False" />

                        <!-- Update available panel -->
                        <Border
                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                            CornerRadius="6"
                            Padding="12"
                            Visibility="{x:Bind ViewModel.IsUpdateAvailable, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Spacing="12">

                                <TextBlock
                                    Text="{x:Bind ViewModel.AvailableUpdate.ReleaseName, Mode=OneWay}"
                                    FontWeight="SemiBold"
                                    AutomationProperties.Name="Available update name" />

                                <!-- Action buttons -->
                                <StackPanel
                                    Orientation="Horizontal"
                                    Spacing="8"
                                    Visibility="{x:Bind ViewModel.IsNotDownloadingUpdate, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Button
                                        x:Uid="SettingsPage_DownloadInstallBtn"
                                        Content="Download &amp; Install"
                                        Command="{x:Bind ViewModel.DownloadAndInstallCommand}"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        AutomationProperties.Name="Download and install update" />
                                    <Button
                                        x:Uid="SettingsPage_ReleaseNotesBtn"
                                        Content="View Release Notes"
                                        Command="{x:Bind ViewModel.OpenReleasePageCommand}"
                                        AutomationProperties.Name="Open release notes in browser" />
                                </StackPanel>

                                <!-- Download progress -->
                                <StackPanel
                                    Spacing="6"
                                    Visibility="{x:Bind ViewModel.IsDownloadingUpdate, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <Grid ColumnSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <ProgressBar
                                            Grid.Column="0"
                                            Value="{x:Bind ViewModel.DownloadProgress, Mode=OneWay}"
                                            Minimum="0"
                                            Maximum="100"
                                            VerticalAlignment="Center"
                                            AutomationProperties.Name="Download progress" />
                                        <TextBlock
                                            Grid.Column="1"
                                            Text="{x:Bind ViewModel.DownloadProgressText, Mode=OneWay}"
                                            Style="{ThemeResource CaptionTextBlockStyle}"
                                            VerticalAlignment="Center" />
                                    </Grid>
                                    <Button
                                        x:Uid="SettingsPage_CancelBtn"
                                        Content="Cancel"
                                        Command="{x:Bind ViewModel.DownloadAndInstallCancelCommand}"
                                        AutomationProperties.Name="Cancel download" />
                                </StackPanel>

                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Language -->
            <StackPanel Spacing="8">
                <TextBlock
                    x:Uid="SettingsPage_LanguageSection"
                    Style="{ThemeResource SubtitleTextBlockStyle}" />

                <Border
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                    <StackPanel Spacing="12">

                        <StackPanel Spacing="4">
                            <TextBlock
                                x:Uid="SettingsPage_LanguageLabel"
                                Style="{ThemeResource CaptionTextBlockStyle}" />
                            <ComboBox
                                ItemsSource="{x:Bind ViewModel.AvailableLanguages}"
                                SelectedItem="{x:Bind ViewModel.SelectedLanguage, Mode=TwoWay}"
                                MinWidth="200"
                                AutomationProperties.Name="Application language">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="viewmodels:LanguageOption">
                                        <TextBlock Text="{x:Bind DisplayName}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <Button
                            x:Uid="SettingsPage_ApplyLanguageBtn"
                            Command="{x:Bind ViewModel.ApplyLanguageCommand}"
                            AutomationProperties.Name="Apply language change" />

                        <InfoBar
                            x:Uid="SettingsPage_RestartNote"
                            IsOpen="{x:Bind ViewModel.RestartRequired, Mode=OneWay}"
                            Severity="Warning"
                            IsClosable="False" />

                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
