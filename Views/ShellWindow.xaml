<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="iscWBS.Views.ShellWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:iscWBS.Views">

    <Grid x:Name="RootGrid">
        <NavigationView
            x:Name="NavView"
            PaneDisplayMode="LeftCompact"
            IsSettingsVisible="False"
            IsBackButtonVisible="Collapsed"
            ItemInvoked="NavView_ItemInvoked">

            <NavigationView.MenuItems>
                <NavigationViewItem
                    Tag="DashboardPage"
                    Content="Dashboard"
                    AutomationProperties.Name="Dashboard"
                    IsEnabled="{x:Bind ViewModel.HasActiveProject, Mode=OneWay}">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem
                    Tag="WbsTreePage"
                    Content="WBS Tree"
                    AutomationProperties.Name="WBS Tree"
                    IsEnabled="{x:Bind ViewModel.HasActiveProject, Mode=OneWay}">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8BE;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem
                    Tag="WbsOutlinePage"
                    Content="WBS Outline"
                    AutomationProperties.Name="WBS Outline"
                    IsEnabled="{x:Bind ViewModel.HasActiveProject, Mode=OneWay}">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8A5;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem
                    Tag="GanttPage"
                    Content="Gantt"
                    AutomationProperties.Name="Gantt"
                    IsEnabled="{x:Bind ViewModel.HasActiveProject, Mode=OneWay}">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE877;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem
                    Tag="ReportsPage"
                    Content="Reports"
                    AutomationProperties.Name="Reports"
                    IsEnabled="{x:Bind ViewModel.HasActiveProject, Mode=OneWay}">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D2;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem
                    Tag="SettingsPage"
                    Content="Settings"
                    AutomationProperties.Name="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Frame x:Name="ContentFrame" />
        </NavigationView>
    </Grid>
</Window>
