<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="iscWBS.Views.WbsOutlinePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:iscWBS.Core.Models"
    xmlns:converters="using:iscWBS.Converters">

    <Page.Resources>
        <converters:StatusToStringConverter x:Key="StatusToStringConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel
            Grid.Row="0"
            Orientation="Horizontal"
            Spacing="8"
            Padding="12,8">
            <TextBlock
                Text="WBS Outline"
                Style="{ThemeResource SubtitleTextBlockStyle}"
                VerticalAlignment="Center" />
        </StackPanel>

        <!-- Column headers -->
        <Grid Grid.Row="1" Padding="12,4" Background="{ThemeResource SubtleFillColorSecondaryBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="100" />
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="90" />
                <ColumnDefinition Width="110" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Code" FontWeight="SemiBold" />
            <TextBlock Grid.Column="1" Text="Title" FontWeight="SemiBold" />
            <TextBlock Grid.Column="2" Text="Assigned To" FontWeight="SemiBold" />
            <TextBlock Grid.Column="3" Text="Status" FontWeight="SemiBold" />
            <TextBlock Grid.Column="4" Text="Est. Hours" FontWeight="SemiBold" />
            <TextBlock Grid.Column="5" Text="Act. Hours" FontWeight="SemiBold" />
            <TextBlock Grid.Column="6" Text="Est. Cost" FontWeight="SemiBold" />
            <TextBlock Grid.Column="7" Text="Act. Cost" FontWeight="SemiBold" />
            <TextBlock Grid.Column="8" Text="Due Date" FontWeight="SemiBold" />
        </Grid>

        <ListView
            x:Name="OutlineListView"
            Grid.Row="2"
            ItemsSource="{x:Bind ViewModel.Nodes, Mode=OneWay}"
            SelectionMode="Single"
            SelectionChanged="OutlineListView_SelectionChanged"
            AutomationProperties.Name="WBS outline">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="12,4" />
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="models:WbsNode">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="90" />
                            <ColumnDefinition Width="110" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Bind Code}" FontWeight="SemiBold" />
                        <TextBlock Grid.Column="1" Text="{x:Bind Title}" />
                        <TextBlock Grid.Column="2" Text="{x:Bind AssignedTo}" />
                        <TextBlock Grid.Column="3" Text="{x:Bind Status, Converter={StaticResource StatusToStringConverter}}" />
                        <TextBlock Grid.Column="4" Text="{x:Bind EstimatedHours}" />
                        <TextBlock Grid.Column="5" Text="{x:Bind ActualHours}" />
                        <TextBlock Grid.Column="6" Text="{x:Bind EstimatedCost}" />
                        <TextBlock Grid.Column="7" Text="{x:Bind ActualCost}" />
                        <TextBlock Grid.Column="8" Text="{x:Bind DueDate}" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
