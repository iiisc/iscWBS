<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="iscWBS.Views.WbsTreePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:iscWBS.ViewModels"
    xmlns:controls="using:iscWBS.Views.Controls"
    xmlns:converters="using:iscWBS.Converters">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <StackPanel
            Grid.Row="0"
            Orientation="Horizontal"
            Spacing="8"
            Padding="12,8">
            <Button
                Content="Add Root Node"
                Command="{x:Bind ViewModel.AddRootNodeCommand}"
                AutomationProperties.Name="Add root node" />
            <Button
                Content="Add Child"
                Command="{x:Bind ViewModel.AddChildNodeCommand}"
                CommandParameter="{x:Bind ViewModel.SelectedNode, Mode=OneWay}"
                IsEnabled="{x:Bind ViewModel.IsDetailVisible, Mode=OneWay}"
                AutomationProperties.Name="Add child node" />
            <Button
                Content="Delete Node"
                Command="{x:Bind ViewModel.DeleteNodeCommand}"
                CommandParameter="{x:Bind ViewModel.SelectedNode, Mode=OneWay}"
                IsEnabled="{x:Bind ViewModel.IsDetailVisible, Mode=OneWay}"
                AutomationProperties.Name="Delete selected node" />
            <Rectangle Width="1" Height="20" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" VerticalAlignment="Center" />
            <Button
                Content="Collapse All"
                Click="CollapseAll_Click"
                AutomationProperties.Name="Collapse all nodes" />
            <Button
                Content="Expand All"
                Click="ExpandAll_Click"
                AutomationProperties.Name="Expand all nodes" />
        </StackPanel>

        <!-- Content: Diagram + Detail Panel -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="320" />
                <ColumnDefinition Width="1" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <!-- WBS Diagram -->
            <Grid Grid.Column="0">
                <controls:WbsDiagramControl
                    x:Name="WbsDiagram"
                    AllNodes="{x:Bind ViewModel.DiagramNodes, Mode=OneWay}"
                    SelectedNodeId="{x:Bind ViewModel.SelectedNodeId, Mode=OneWay}">
                    <FlyoutBase.AttachedFlyout>
                        <MenuFlyout>
                            <MenuFlyoutItem
                                Text="Add Child"
                                Command="{x:Bind ViewModel.AddChildNodeCommand}"
                                CommandParameter="{x:Bind ViewModel.SelectedNode, Mode=OneWay}"
                                AutomationProperties.Name="Add child node" />
                            <MenuFlyoutItem
                                Text="Add Sibling"
                                Command="{x:Bind ViewModel.AddSiblingNodeCommand}"
                                CommandParameter="{x:Bind ViewModel.SelectedNode, Mode=OneWay}"
                                AutomationProperties.Name="Add sibling node" />
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem
                                Text="Delete"
                                Command="{x:Bind ViewModel.DeleteNodeCommand}"
                                CommandParameter="{x:Bind ViewModel.SelectedNode, Mode=OneWay}"
                                AutomationProperties.Name="Delete node" />
                        </MenuFlyout>
                    </FlyoutBase.AttachedFlyout>
                </controls:WbsDiagramControl>

                <StackPanel
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="8"
                    IsHitTestVisible="False"
                    Visibility="{x:Bind ViewModel.HasNoNodes, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock
                        Text="No nodes yet"
                        Style="{ThemeResource SubtitleTextBlockStyle}"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock
                        Text="Click &#x2018;Add Root Node&#x2019; to get started"
                        Style="{ThemeResource CaptionTextBlockStyle}"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                </StackPanel>
            </Grid>

            <!-- Separator -->
            <Rectangle
                Grid.Column="1"
                Fill="{ThemeResource DividerStrokeColorDefaultBrush}"
                Width="1" />

            <!-- Detail Panel -->
            <controls:WbsDetailControl
                x:Name="DetailControl"
                Grid.Column="2"
                ViewModel="{x:Bind ViewModel, Mode=OneWay}"
                Visibility="{x:Bind ViewModel.IsDetailVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
        </Grid>
    </Grid>
</Page>
