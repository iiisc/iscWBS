<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="iscWBS.Views.WelcomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12"
                MaxWidth="420"
                Padding="32">

                <TextBlock
                    Text="iscWBS"
                    Style="{ThemeResource DisplayTextBlockStyle}"
                    HorizontalAlignment="Center" />

                <TextBlock
                    Text="Project Management &amp; Work Breakdown Structure"
                    Style="{ThemeResource BodyTextBlockStyle}"
                    HorizontalAlignment="Center"
                    TextAlignment="Center"
                    Margin="0,0,0,12" />

                <Button
                    x:Name="BtnNewProject"
                    Content="New Project"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="Create a new project"
                    Click="BtnNewProject_Click" />

                <Button
                    x:Name="BtnOpenProject"
                    Content="Open Project"
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="Open an existing project file"
                    Click="BtnOpenProject_Click" />

                <StackPanel
                    Spacing="8"
                    Margin="0,16,0,0"
                    Visibility="{x:Bind ViewModel.HasRecentProjects, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">

                    <TextBlock
                        Text="Recent Projects"
                        Style="{ThemeResource SubtitleTextBlockStyle}" />

                    <ListView
                        x:Name="RecentProjectsList"
                        ItemsSource="{x:Bind ViewModel.RecentProjects, Mode=OneWay}"
                        IsItemClickEnabled="True"
                        SelectionMode="None"
                        MaxHeight="240"
                        ItemClick="RecentProjectsList_ItemClick">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock
                                    Text="{x:Bind}"
                                    TextTrimming="CharacterEllipsis"
                                    ToolTipService.ToolTip="{x:Bind}" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
